4. User-Defined Exception Example

CREATE OR REPLACE PROCEDURE UscExc(
m1 IN NUMBER,
m2 IN NUMBER,
m3 IN NUMBER
)
AS
Invalid_marks EXCEPTION;
BEGIN
IF m1 < 0 OR m1 > 100 OR
m2 < 0 OR m2 > 100 OR
m3 < 0 OR m3 > 100 THEN
RAISE Invalid_marks;

ELSIF m1 >= 50 OR m2 >= 50 OR m3 >= 50 THEN
DBMS_OUTPUT.PUT_LINE('Result = Pass');

ELSE
DBMS_OUTPUT.PUT_LINE('Result = Fail');
END IF;

EXCEPTION
WHEN Invalid_marks THEN
DBMS_OUTPUT.PUT_LINE('Enter valid marks in range (0-100)');
END;
/

EXEC UscExc(10, 105, 51);
-- Enter valid marks in range (0-100)

EXEC UscExc(55, 55, 55);
-- Result = Pass

EXEC UscExc(17, -55, 16);
-- Enter valid marks in range (0-100)
