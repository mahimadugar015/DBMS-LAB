# Example of IF – ELSE IF – ELSE condition

CREATE OR REPLACE PROCEDURE FindGreatest AS
  a NUMBER := 5;
  b NUMBER := 15;
  c NUMBER := 10;
BEGIN
  IF a > b AND a > c THEN
    DBMS_OUTPUT.PUT_LINE('A is greatest: ' || a);

  ELSIF b > a AND b > c THEN
    DBMS_OUTPUT.PUT_LINE('B is greatest: ' || b);

  ELSE
    DBMS_OUTPUT.PUT_LINE('C is greatest: ' || c);
  END IF;
END;
/

EXEC FindGreatest;

# OUTPUT
# B is greatest: 15


# ------------------------------------------------
# CASE 1 : Procedure with fixed marks
# ------------------------------------------------

CREATE OR REPLACE PROCEDURE Stud_Result
AS 
  CS NUMBER := 45;       # marks in Computer Science
  OS NUMBER := 75;       # marks in Operating System
  DBMS NUMBER := 0;      # marks in DBMS
  MATH NUMBER := 25;     # marks in Maths
  total NUMBER;
  per NUMBER;
BEGIN 
  total := CS + OS + DBMS + MATH;       # calculate total marks
  per := (total / 400) * 100;           # calculate percentage

  # check for fail
  IF CS < 35 AND OS < 35 AND DBMS < 35 AND MATH < 35 THEN
    DBMS_OUTPUT.PUT_LINE('FAIL');
  ELSE
    # determine division based on percentage
    IF per > 75 THEN
       DBMS_OUTPUT.PUT_LINE('DIVISION A');
    ELSIF per > 65 THEN
       DBMS_OUTPUT.PUT_LINE('DIVISION B');
    ELSIF per > 55 THEN
       DBMS_OUTPUT.PUT_LINE('SECONDARY DIVISION');
    ELSE
       DBMS_OUTPUT.PUT_LINE('THIRD DIVISION');
    END IF;

    DBMS_OUTPUT.PUT_LINE('TOTAL MARKS: ' || total);
    DBMS_OUTPUT.PUT_LINE('PERCENTAGE: ' || per);
  END IF;
END;
/

SET SERVEROUTPUT ON;

# execute CASE 1
EXEC Stud_Result;

# OUTPUT
# THIRD DIVISION
# TOTAL MARKS: 145
# PERCENTAGE: 36.25



# ------------------------------------------------
# CASE 2 : Procedure with CS as input, others fixed
# ------------------------------------------------

CREATE OR REPLACE PROCEDURE Stud_Result_CS_Input(p_CS IN NUMBER)
AS 
  OS NUMBER := 75;       # fixed Operating System marks
  DBMS NUMBER := 0;      # fixed DBMS marks
  MATH NUMBER := 25;     # fixed Maths marks
  total NUMBER;
  per NUMBER;
BEGIN 
  total := p_CS + OS + DBMS + MATH;       # calculate total marks
  per := (total / 400) * 100;             # calculate percentage

  # check for fail
  IF p_CS < 35 OR OS < 35 OR DBMS < 35 OR MATH < 35 THEN
    DBMS_OUTPUT.PUT_LINE('FAIL');
  ELSE
    # determine division based on percentage
    IF per > 75 THEN
       DBMS_OUTPUT.PUT_LINE('DIVISION A');
    ELSIF per > 65 THEN
       DBMS_OUTPUT.PUT_LINE('DIVISION B');
    ELSIF per > 55 THEN
       DBMS_OUTPUT.PUT_LINE('SECONDARY DIVISION');
    ELSE
       DBMS_OUTPUT.PUT_LINE('THIRD DIVISION');
    END IF;

    DBMS_OUTPUT.PUT_LINE('TOTAL MARKS: ' || total);
    DBMS_OUTPUT.PUT_LINE('PERCENTAGE: ' || per);
  END IF;
END;
/

SET SERVEROUTPUT ON;

# Execute CASE 2 with CS input = 60
EXEC Stud_Result_CS_Input(60);

# OUTPUT
# FIRST DIVISION
# TOTAL MARKS: 160
# PERCENTAGE: 40
