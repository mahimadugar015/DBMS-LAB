------------------------------------------------------------
2) Correct Procedure – helloworld
------------------------------------------------------------

CREATE PROCEDURE helloworld
AS
BEGIN
    DBMS_OUTPUT.PUT_LINE('Hello World!');
END;
/

SET SERVEROUTPUT ON;
EXEC helloworld;

-- Output:
-- Hello World!
-- PL/SQL procedure successfully completed.


