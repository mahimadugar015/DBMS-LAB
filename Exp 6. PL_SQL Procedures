------------------------------------------------------------
4) Procedure Without Parameters
------------------------------------------------------------

CREATE OR REPLACE PROCEDURE add_1
AS
    a NUMBER;
    b NUMBER;
BEGIN
    a := 5;
    b := 10;
    DBMS_OUTPUT.PUT_LINE('Result: ' || (a + b));
END;
/

SET SERVEROUTPUT ON;
EXEC add_1;

-- Output:
-- Result: 15


------------------------------------------------------------
5) Procedure With IN Parameters
------------------------------------------------------------

CREATE OR REPLACE PROCEDURE add_1(
    a IN NUMBER,
    b IN NUMBER
)
AS
BEGIN
    DBMS_OUTPUT.PUT_LINE('Result: ' || (a + b));
END;
/

-- Incorrect Execution:
-- EXEC add_1;
-- Error: PLS-00306 (wrong number or types of arguments)

-- Correct Execution:
EXEC add_1(5, 10);

-- Output:
-- Result: 15


------------------------------------------------------------
6) Procedure With OUT Parameter
------------------------------------------------------------

CREATE OR REPLACE PROCEDURE add_2(
    a IN NUMBER,
    b IN NUMBER,
    c OUT NUMBER
)
AS
BEGIN
    c := a + b;
    DBMS_OUTPUT.PUT_LINE('Result: ' || c);
END;
/

VARIABLE c1 NUMBER;
EXEC add_2(5, 10, :c1);

-- Output:
-- Result: 15


------------------------------------------------------------
7) Swapping Two Numbers (Without Third Variable)
------------------------------------------------------------

CREATE OR REPLACE PROCEDURE swap_1(
    x IN OUT NUMBER,
    y IN OUT NUMBER
)
AS
BEGIN
    x := x + y;
    y := x - y;
    x := x - y;

    DBMS_OUTPUT.PUT_LINE('Value of x: ' || x);
    DBMS_OUTPUT.PUT_LINE('Value of y: ' || y);
END;
/

SQL> Set ServerOutput ON;
SQL> VARIABLE a NUMBER;
SQL> VARIABLE b NUMBER;

SQL> EXEC :a := 5;

---PL/SQL procedure successfully completed.

SQL> EXEC :b := 10;

---PL/SQL procedure successfully completed.

SQL> EXEC swap_1(:a, :b);
---Value of x: 10
---Value of y: 5

---PL/SQL procedure successfully completed.

------------------------------------------------------------
8) Find Largest Among Three Numbers
------------------------------------------------------------

CREATE OR REPLACE PROCEDURE largest_3(
    a IN NUMBER,
    b IN NUMBER,
    c IN NUMBER
)
AS
BEGIN
    IF a > b AND a > c THEN
        DBMS_OUTPUT.PUT_LINE('Largest number is: ' || a);
    ELSIF b > a AND b > c THEN
        DBMS_OUTPUT.PUT_LINE('Largest number is: ' || b);
    ELSE
        DBMS_OUTPUT.PUT_LINE('Largest number is: ' || c);
    END IF;
END;
/

EXEC largest_3(10, 25, 15);

---Largest number is: 25

---PL/SQL procedure successfully completed.
