# ------------------------------------------------
# EXP 7 – SUM OF FIRST n NUMBERS USING LOOPS
# ------------------------------------------------

# Procedure to calculate sum of first n numbers using WHILE loop

CREATE OR REPLACE PROCEDURE SumFirst_n_Numbers_WhileLoop(
n IN NUMBER)
AS
    i NUMBER := 1;
    sum1 NUMBER := 0;
BEGIN
    WHILE i <= n LOOP
        sum1 := sum1 + i;
        i := i + 1;
    END LOOP;
    DBMS_OUTPUT.PUT_LINE('Sum of first n numbers using WHILE loop: ' || sum1);
END;
/

SET SERVEROUTPUT ON;

EXEC SumFirst_n_Numbers_WhileLoop(10);

# OUTPUT
# Sum of first n numbers using WHILE loop: 55

EXEC SumFirst_n_Numbers_WhileLoop(5);

# OUTPUT
# Sum of first n numbers using WHILE loop: 15


# ------------------------------------------------
# SUM OF FIRST n NUMBERS USING WHILE LOOP WITH EXIT
# ------------------------------------------------

# Procedure using EXIT condition inside the loop

CREATE OR REPLACE PROCEDURE SumFirst_n_Numbers_While(
n IN NUMBER)
AS
    i NUMBER := 1;
    sum1 NUMBER := 0;
BEGIN
    WHILE i != 0 LOOP
        sum1 := sum1 + i;
        EXIT WHEN i = n;
        i := i + 1;
    END LOOP;

    DBMS_OUTPUT.PUT_LINE('Sum of first n numbers using WHILE loop: ' || sum1);
END;
/

EXEC SumFirst_n_Numbers_While(10);

# OUTPUT
# Sum of first n numbers using WHILE loop: 55


# ------------------------------------------------
# SUM OF FIRST n NUMBERS USING FOR LOOP
# ------------------------------------------------

# Procedure to calculate sum using FOR loop

CREATE OR REPLACE PROCEDURE SumFirst_n_Numbers_ForLoop(
n IN NUMBER)
AS
    sum1 NUMBER := 0;
BEGIN
    FOR i IN 1..n LOOP
        sum1 := sum1 + i;
    END LOOP;

    DBMS_OUTPUT.PUT_LINE('Sum of first n numbers using FOR loop: ' || sum1);
END;
/

EXEC SumFirst_n_Numbers_ForLoop(10);

# OUTPUT
# Sum of first n numbers using FOR loop: 55


# ------------------------------------------------
# SUM USING REVERSE FOR LOOP
# ------------------------------------------------

# Using REVERSE keyword to run the loop from n to 1

CREATE OR REPLACE PROCEDURE SumFirst_n_Numbers_ForLoop(
n IN NUMBER)
AS
    sum1 NUMBER := 0;
BEGIN
    FOR i REVERSE IN 1..n LOOP
        sum1 := sum1 + i;
    END LOOP;

    DBMS_OUTPUT.PUT_LINE('Sum of first n numbers using FOR loop: ' || sum1);
END;
/
