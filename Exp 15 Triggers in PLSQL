## 6. Function: Check Salary Based on Category

CREATE OR REPLACE FUNCTION check_salary (
p_category NUMBER,
p_salary   NUMBER
) RETURN VARCHAR2 IS
BEGIN
IF p_category = 1 AND p_salary <= 10000 THEN
RETURN 'Salary must be > 10000 for category 1';
ELSIF p_category = 2 AND p_salary <= 20000 THEN  
    RETURN 'Salary must be > 20000 for category 2';  
ELSIF p_category = 3 AND p_salary <= 30000 THEN  
    RETURN 'Salary must be > 30000 for category 3';  
ELSE  
    RETURN 'Valid Salary';  
END IF;  
END;
/


## 7. Function Execution

SELECT check_salary(1, 8000) AS result FROM dual;
-- OUTPUT: Salary must be > 10000 for category 1

SELECT check_salary(2, 8000) AS result FROM dual;
-- OUTPUT: Salary must be > 20000 for category 2

SELECT check_salary(3, 50000) AS result FROM dual;
-- OUTPUT: Valid Salary


